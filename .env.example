# Copy this file to `.env` (which is .gitignored) and fill in values.
# docker-compose reads `.env` automatically at runtime.
#
# API keys are ONLY needed when LangGraph agent nodes are wired up
# (post-pilot sprint). Training-only runs do not require any key.

# ---- LLM Providers (agent wire-up sprint) -------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ---- Optional per-agent overrides (otherwise LLM_ROUTING defaults) -
# AES_LLM_ARCHITECT=claude-opus-4-6
# AES_LLM_TRAINING_ENGINEER=gpt-5.3-codex
# AES_LLM_EVALUATOR=claude-sonnet-4-6

# ---- HuggingFace (optional, for gated models) ---------------------
# HF_TOKEN=
