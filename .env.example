# =================================================================
# AES Thesis — Agent System Environment Configuration (EXAMPLE)
# =================================================================
# Bu dosyayı `.env` olarak kopyalayın ve API key'lerinizi girin.
# `.env` dosyası .gitignore'dadır — commit edilmez.
#
# LLM Dağılımı (rev2 — performans odaklı):
#   8x Claude Opus 4.6   → ANTHROPIC_API_KEY gerekli
#   5x Claude Sonnet 4.6 → ANTHROPIC_API_KEY gerekli
#   2x GPT (5.3/5.4)     → OPENAI_API_KEY gerekli
#   1x Gemini 3.1 Pro    → GOOGLE_API_KEY gerekli
# =================================================================

# ---- LLM Provider API Keys ----------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...

# ---- HuggingFace (gated modeller için) ----------------------------
# HF_TOKEN=hf_...

# ---- Per-Agent LLM Override (opsiyonel) ----------------------------
# graph.py LLM_ROUTING varsayılanlarını override etmek için:
# AES_LLM_ARCHITECT=claude-opus-4-6
# AES_LLM_TRAINING_ENGINEER=claude-opus-4-6
# AES_LLM_DATA_ANALYST=claude-opus-4-6
